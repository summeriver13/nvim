# Neovim 配置 gitignore - 个人使用版本

# Neovim 运行时日志
.nvimlog
*.log

# 交换文件和备份
*.swp
*.swo
*~
.*.swp
.*.swo
*.tmp
*.bak
*.backup
*.old

# 会话文件
Session.vim
*.session
*.session.lock

# 标签文件
tags
.tags
.tags_sorted_by_file

# 插件编译产物（如果使用 packer.nvim 或其他插件管理器）
pack/*/opt/*/target/
pack/*/start/*/target/

# 语言服务器和缓存文件
.cache/
*.pyc
__pycache__/
.coverage
.pytest_cache/
.mypy_cache/

# Node.js 相关
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 项目特定临时文件
*.luac
*.so
*.dylib
*.dll

# 测试输出
test-results/
*.test
*.spec

# 测试生成的临时文件
test-load.lua
test-func.lua
test-ai-functionality.lua
test-*.lua

# 环境变量文件
.env
.env.local
.env.*.local

# IDE 和编辑器文件
.vscode/
.idea/
*.swp
*.sublime-*

# 系统文件
.DS_Store
Thumbs.db

# 重要说明：
# lazy-lock.json 被保留（已提交到版本控制）
# 这是 lazy.nvim 的版本锁定文件，提交它可以确保在不同机器上插件版本一致